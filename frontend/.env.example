VITE_BACKEND_URL=http://localhost:8080

# Optional: ICE servers for WebRTC reliability (STUN/TURN)
# Provide a JSON array of RTCIceServer objects.
# - For local/dev: a public STUN server is often enough.
# - For real demos across networks: add a TURN server (do NOT commit real credentials).
#
# Example:
# VITE_ICE_SERVERS=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["turn:turn.example.com:3478"],"username":"demo-user","credential":"demo-pass"}]

# Gesture pipeline (client-side)
VITE_GESTURE_MODEL_URL=/models/gesture/model.json
# Optional: JSON array of labels, e.g. ["HELLO","THANK_YOU",...]
# VITE_GESTURE_LABELS_URL=/models/gesture/labels.json
VITE_GESTURE_CONFIDENCE_THRESHOLD=0.85

# MediaPipe Hands local assets base path (served by frontend)
VITE_MEDIAPIPE_HANDS_BASE_PATH=/mediapipe/hands/

